---
import PageLayout from '../layouts/PageLayout.astro';
---
<PageLayout title="Resume">
  <div class="pdf-wrapper">
    <div class="pdf-toolbar">
      <a class="pdf-btn" href="https://ontheline.trincoll.edu/images/bookdown/sample-local-pdf.pdf" download>Download</a>
    </div>
    <div class="pdf-canvas-container" id="pdf-container"></div>
  </div>

  <button class="back-to-top" id="back-to-top" aria-label="Back to top">
    ↑ Top
  </button>
</PageLayout>

<style>
  .pdf-wrapper {
    width: 40vw;
    margin: 2rem auto;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  @media (max-width: 768px) {
    .pdf-wrapper {
      width: 90vw;
    }
  }

  .pdf-toolbar {
    display: flex;
    gap: 0.75rem;
    justify-content: center;
    padding-bottom: 1.5rem;
  }

  .pdf-btn {
    font-family: 'Special Gothic Expanded One', sans-serif;
    font-size: 0.62rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--ink);
    text-decoration: none;
    background: var(--bg);
    padding: 0.6rem 1.25rem;
    border: 1px solid rgba(255, 248, 231, 0.22);
    border-radius: 999px;
    transition: border-color 0.2s ease;
  }

  .pdf-btn:hover {
    border-color: rgba(255, 248, 231, 0.5);
  }

  .pdf-canvas-container {
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .pdf-canvas-container canvas {
    width: 100%;
    height: auto;
    display: block;
  }

  /* Back to top — floating pill, same language as mobile nav pills */
  .back-to-top {
    position: fixed;
    bottom: calc(1.5rem + env(safe-area-inset-bottom, 0px));
    right: 1.5rem;
    font-family: 'Special Gothic Expanded One', sans-serif;
    font-size: 0.62rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--ink);
    background: var(--bg);
    border: 1px solid rgba(255, 248, 231, 0.22);
    border-radius: 999px;
    padding: 0.6rem 1.25rem;
    cursor: pointer;
    z-index: 10;
    opacity: 0;
    pointer-events: none;
    transform: translateY(6px);
    transition: opacity 0.3s ease, transform 0.3s ease, border-color 0.2s ease;
  }

  .back-to-top.visible {
    opacity: 1;
    pointer-events: auto;
    transform: translateY(0);
  }

  .back-to-top:hover {
    border-color: rgba(255, 248, 231, 0.5);
    transform: translateY(-2px);
  }

  /* On mobile the pill-toggle sits at bottom 1.5rem + safe-area.
     Stack the back-to-top above it with the same 0.4rem gap the pill links use.
     ~2rem accounts for the toggle's padding + line-height. */
  @media (max-width: 640px) {
    .back-to-top {
      /* toggle height is ~2.15rem; 0.4rem matches pill-links gap */
      bottom: calc(1.5rem + env(safe-area-inset-bottom, 0px) + 2.15rem + 0.4rem);
    }
  }
</style>

<script type="module">
  const PDF_URL = 'https://ontheline.trincoll.edu/images/bookdown/sample-local-pdf.pdf';
  const PDFJS_VERSION = '4.4.168';
  const PDFJS_CDN = `https://cdnjs.cloudflare.com/ajax/libs/pdf.js/${PDFJS_VERSION}`;

  const { GlobalWorkerOptions, getDocument } = await import(`${PDFJS_CDN}/pdf.min.mjs`);
  GlobalWorkerOptions.workerSrc = `${PDFJS_CDN}/pdf.worker.min.mjs`;

  const container = document.getElementById('pdf-container');
  const pdf = await getDocument(PDF_URL).promise;

  for (let i = 1; i <= pdf.numPages; i++) {
    const page = await pdf.getPage(i);
    const viewport = page.getViewport({ scale: 1.5 });

    const canvas = document.createElement('canvas');
    canvas.width = viewport.width;
    canvas.height = viewport.height;
    container.appendChild(canvas);

    await page.render({ canvasContext: canvas.getContext('2d'), viewport }).promise;
  }
</script>

<script>
  const btn = document.getElementById('back-to-top');
  if (btn) {
    window.addEventListener('scroll', () => {
      btn.classList.toggle('visible', window.scrollY > 300);
    }, { passive: true });

    btn.addEventListener('click', () => {
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });
  }
</script>
