---
import PageLayout from '../layouts/PageLayout.astro';
---
<PageLayout title="Socials">
  <div class="socials-card">
    <a href="https://github.com/ajmarkow" target="_blank" rel="noopener noreferrer" aria-label="GitHub">
      <img src="https://cdn.jsdelivr.net/npm/simple-icons@v11/icons/github.svg" alt="GitHub" />
    </a>
    <a href="https://linkedin.com/in/ajmarkow" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">
      <img src="https://cdn.jsdelivr.net/npm/simple-icons@v11/icons/linkedin.svg" alt="LinkedIn" />
    </a>
  </div>
</PageLayout>
